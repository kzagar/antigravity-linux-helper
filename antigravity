#!/usr/bin/env python3
"""Launcher and auto-updater for Google Antigravity and Antigravity IDE.

Detects which application to run from argv[0], checks for updates at most
once per hour, performs an atomic installation under ~/.local/opt/, and
exec-replaces itself with the installed binary.
"""

import datetime
import gzip
import json
import os
import platform
import re
import shutil
import sys
import tarfile
import urllib.request

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

DOWNLOAD_PAGE_URL = "https://antigravity.google/download"
BASE_URL = "https://antigravity.google"
BRAND_LOGO_URL = (
    "https://antigravity.google/assets/image/brand/antigravity-icon__full-color.png"
)

# Section IDs as embedded in the download-page JS bundle
APP_SECTION_IDS = {
    "antigravity": "antigravity-2",
    "antigravity-ide": "antigravity-ide",
}

# Maximum time (seconds) to wait for an archive download before giving up
DOWNLOAD_TIMEOUT = 600

# ---------------------------------------------------------------------------
# User / permission helpers
# ---------------------------------------------------------------------------


def get_user_home():
    """Return the home directory of the invoking user, handling sudo."""
    sudo_user = os.environ.get("SUDO_USER")
    if sudo_user:
        import pwd  # pylint: disable=import-outside-toplevel

        try:
            return pwd.getpwnam(sudo_user).pw_dir
        except KeyError:
            pass
    return os.path.expanduser("~")


def get_user_uid_gid():
    """Return the (uid, gid) of the invoking user, handling sudo."""
    sudo_uid = os.environ.get("SUDO_UID")
    sudo_gid = os.environ.get("SUDO_GID")
    if sudo_uid and sudo_gid:
        return int(sudo_uid), int(sudo_gid)
    return os.getuid(), os.getgid()


def chown_to_user(path):
    """Recursively chown *path* to the invoking user (no-op when not root)."""
    if os.getuid() != 0:
        return
    uid, gid = get_user_uid_gid()
    try:
        if os.path.isdir(path):
            os.chown(path, uid, gid)
            for root, dirs, files in os.walk(path):
                for name in dirs:
                    os.chown(os.path.join(root, name), uid, gid)
                for name in files:
                    os.chown(os.path.join(root, name), uid, gid)
        else:
            os.chown(path, uid, gid)
    except OSError as exc:
        print(f"Warning: Failed to chown {path} to user: {exc}", file=sys.stderr)


# ---------------------------------------------------------------------------
# Filesystem search helpers
# ---------------------------------------------------------------------------


def find_file_recursive(dir_path, name, is_executable=False):
    """Return the shallowest file named *name* under *dir_path*.

    When *is_executable* is True only executable files are considered.
    Returns ``None`` if no match is found.
    """
    matches = []
    for root, _, files in os.walk(dir_path):
        if name in files:
            full_path = os.path.join(root, name)
            if not is_executable or os.access(full_path, os.X_OK):
                matches.append((full_path.count(os.sep), full_path))
    if matches:
        return min(matches)[1]
    return None


def find_icon_recursive(dir_path, app_name):
    """Return the best-scored PNG/SVG icon found under *dir_path*.

    Scoring heuristic (higher wins):
      ``code``     → +10
      ``logo``     → +8
      ``icon``     → +6
      *app_name*   → +5

    Returns ``None`` when no image file is found.
    """
    candidates = []
    for root, _, files in os.walk(dir_path):
        for name in files:
            if not name.lower().endswith((".png", ".svg")):
                continue
            lower = name.lower()
            score = 0
            if "code" in lower:
                score += 10
            if "logo" in lower:
                score += 8
            if "icon" in lower:
                score += 6
            if app_name in lower:
                score += 5
            candidates.append((score, os.path.join(root, name)))
    if candidates:
        return max(candidates)[1]
    return None


# ---------------------------------------------------------------------------
# HTTP helper
# ---------------------------------------------------------------------------


def fetch_url(url, method="GET", headers=None, timeout=10):
    """Fetch *url* and return ``(body_bytes, http_info)``.

    Transparently decompresses gzip-encoded responses.
    """
    if headers is None:
        headers = {}
    headers.setdefault(
        "User-Agent", "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
    )
    headers.setdefault("Accept-Encoding", "gzip, deflate")

    req = urllib.request.Request(url, method=method, headers=headers)
    with urllib.request.urlopen(req, timeout=timeout) as response:
        info = response.info()
        data = response.read()
        if info.get("Content-Encoding") == "gzip" and data:
            data = gzip.decompress(data)
        return data, info


# ---------------------------------------------------------------------------
# Release discovery
# ---------------------------------------------------------------------------


def get_linux_platform():
    """Return the platform token used in download URLs (``linux-x64`` / ``linux-arm``)."""
    return "linux-arm" if platform.machine() in ("aarch64", "arm64") else "linux-x64"


def discover_download_url(app_name):  # pylint: disable=too-many-locals
    """Scrape the download page to find the Linux download URL for *app_name*.

    Strategy
    --------
    1. Fetch :data:`DOWNLOAD_PAGE_URL` and locate the ``main-*.js`` bundle.
    2. Parse the JS bundle for the product's platforms section.
    3. Extract the Linux href matching the host architecture.
    4. Issue a HEAD request to obtain the ``Last-Modified`` timestamp.

    Returns
    -------
    (download_url, last_modified) : (str, str)
    """
    # 1. Fetch the download page
    try:
        html = fetch_url(DOWNLOAD_PAGE_URL)[0].decode("utf-8", errors="ignore")
    except Exception as exc:
        raise RuntimeError(f"Failed to fetch download page: {exc}") from exc

    # 2. Locate main JS bundle
    js_files = re.findall(r'src="([^"]+/main-[^"]+\.js|main-[^"]+\.js)"', html)
    if not js_files:
        raise RuntimeError("Could not find main script bundle in download page HTML")

    js_url = js_files[0]
    if not js_url.startswith("http"):
        js_url = BASE_URL + "/" + js_url.lstrip("/")

    # 3. Fetch the JS bundle
    try:
        js_content = fetch_url(js_url)[0].decode("utf-8", errors="ignore")
    except Exception as exc:
        raise RuntimeError(f"Failed to fetch script bundle: {exc}") from exc

    # 4. Find the product's platforms section and extract the Linux href.
    #    The bundle embeds data shaped like:
    #      {id:"antigravity-2", platforms:[{os:"linux", links:[{href:"https://...linux-x64..."}]}]}
    section_id = APP_SECTION_IDS[app_name]
    r_platform = get_linux_platform()

    section_pat = re.compile(r'id:"' + re.escape(section_id) + r'"')
    section_match = section_pat.search(js_content)
    if not section_match:
        raise RuntimeError(
            f"Could not find download section '{section_id}' in JS bundle"
        )

    # Bound the search window to this section only
    window_start = section_match.start()
    next_section_pat = re.compile(r'id:"antigravity-')
    next_match = next_section_pat.search(js_content, section_match.end())
    window_end = (
        next_match.start()
        if next_match
        else min(window_start + 50_000, len(js_content))
    )
    window = js_content[window_start:window_end]

    # Extract hrefs containing the target platform token
    hrefs = re.findall(
        r'href:"(https?://[^"]+' + re.escape(r_platform) + r'[^"]+)"', window
    )
    if not hrefs:
        raise RuntimeError(
            f"No Linux ({r_platform}) download link found for '{app_name}' "
            f"in section '{section_id}'"
        )

    download_url = hrefs[0]

    # 5. HEAD request for Last-Modified timestamp
    try:
        _, info = fetch_url(download_url, method="HEAD")
        last_modified = info.get("Last-Modified")
    except Exception as exc:
        raise RuntimeError(
            f"Failed to verify release headers for {download_url}: {exc}"
        ) from exc

    return download_url, last_modified


# ---------------------------------------------------------------------------
# Self-installation
# ---------------------------------------------------------------------------


def self_install():
    """Copy this script to ``~/.local/bin/antigravity`` and create the IDE symlink.

    Skips gracefully when already running from the installed path.
    """
    user_home = get_user_home()
    user_bin = os.path.join(user_home, ".local", "bin")
    target_script = os.path.join(user_bin, "antigravity")
    target_symlink = os.path.join(user_bin, "antigravity-ide")
    curr_script = os.path.abspath(sys.argv[0])

    # Nothing to do if we are already the installed copy
    if os.path.realpath(curr_script) == os.path.realpath(target_script):
        if not os.path.exists(target_symlink):
            try:
                os.symlink("antigravity", target_symlink)
            except OSError as exc:
                print(
                    f"Warning: Could not create symlink {target_symlink}: {exc}",
                    file=sys.stderr,
                )
        return

    os.makedirs(user_bin, exist_ok=True)
    chown_to_user(user_bin)

    # Copy only when missing or different
    should_copy = True
    if os.path.exists(target_script):
        try:
            with open(curr_script, "rb") as f1, open(target_script, "rb") as f2:
                should_copy = f1.read() != f2.read()
        except OSError:
            pass

    if should_copy:
        try:
            shutil.copy2(curr_script, target_script)
            os.chmod(target_script, 0o755)
            chown_to_user(target_script)
        except OSError as exc:
            print(
                f"Warning: Could not self-install script to {target_script}: {exc}",
                file=sys.stderr,
            )

    if not os.path.exists(target_symlink):
        try:
            os.symlink("antigravity", target_symlink)
            chown_to_user(target_symlink)
        except OSError as exc:
            print(
                f"Warning: Could not create symlink {target_symlink}: {exc}",
                file=sys.stderr,
            )


# ---------------------------------------------------------------------------
# Update logic
# ---------------------------------------------------------------------------


def _is_update_due(last_check_file):
    """Return True if no check has been recorded or the last one is ≥ 1 hour ago."""
    if not os.path.exists(last_check_file):
        return True
    try:
        with open(last_check_file, "r", encoding="utf-8") as fh:
            timestamp = float(fh.read().strip())
        age = (
            datetime.datetime.now() - datetime.datetime.fromtimestamp(timestamp)
        ).total_seconds()
        return age >= 3600
    except (OSError, ValueError):
        return True


def _save_check_timestamp(config_dir, last_check_file):
    """Persist the current timestamp as the last-checked time."""
    os.makedirs(config_dir, exist_ok=True)
    chown_to_user(config_dir)
    try:
        with open(last_check_file, "w", encoding="utf-8") as fh:
            fh.write(str(datetime.datetime.now().timestamp()))
        chown_to_user(last_check_file)
    except OSError:
        pass


def _render_progress_bar(label, done, total, width=30):
    """Print an overwriting progress bar line to stdout.

    ``label``  – short prefix shown before the bar (e.g. "Downloading").
    ``done``   – units completed so far.
    ``total``  – total units (0 or None renders an indeterminate spinner).
    ``width``  – number of fill characters in the bar.
    """
    if total:
        filled = int(width * done / total)
        fill = "#" * filled + "-" * (width - filled)
        pct = done * 100 // total
        print(f"\r  {label} [{fill}] {pct:3d}%", end="", flush=True)
    else:
        spinner = r"-\|/"[done % 4]
        fill = "-" * width
        print(f"\r  {label} [{fill}] {spinner}", end="", flush=True)


def _download_and_extract(
    download_url, app_name, new_dir, opt_dir
):  # pylint: disable=too-many-locals
    """Download the archive and extract it (minus the top-level directory) into *new_dir*.

    Returns the path to the resolved executable on success.
    Raises RuntimeError on any failure.
    """
    temp_archive = os.path.join(opt_dir, f"{app_name}_temp.tar.gz")
    try:
        req = urllib.request.Request(
            download_url, headers={"User-Agent": "Mozilla/5.0"}
        )
        with (
            urllib.request.urlopen(req, timeout=DOWNLOAD_TIMEOUT) as response,
            open(temp_archive, "wb") as out_file,
        ):
            raw_total = response.info().get("Content-Length")
            total_bytes = int(raw_total) if raw_total else None
            downloaded = 0
            chunk_size = 1024 * 1024  # 1 MB
            while True:
                chunk = response.read(chunk_size)
                if not chunk:
                    break
                out_file.write(chunk)
                downloaded += len(chunk)
                _render_progress_bar("Downloading...", downloaded, total_bytes)
        print()

        with tarfile.open(temp_archive, "r:gz") as tar:
            safe_members = []
            for member in tar.getmembers():
                parts = member.name.split("/")
                if len(parts) <= 1:
                    continue  # skip top-level directory entry itself
                member.name = "/".join(parts[1:])
                # Reject path-traversal attempts
                if member.name.startswith("/") or ".." in member.name.split("/"):
                    continue
                safe_members.append(member)
            total_members = len(safe_members)
            for i, member in enumerate(safe_members, 1):
                tar.extract(member, path=new_dir)
                _render_progress_bar("Unpacking... ", i, total_members)
        print()

        resolved_bin = find_file_recursive(new_dir, app_name, is_executable=True)
        if not resolved_bin:
            raise RuntimeError(
                f"Executable '{app_name}' not found in extracted archive"
            )
        return resolved_bin

    finally:
        if os.path.exists(temp_archive):
            os.remove(temp_archive)


class Updater:
    """Builder-pattern class for managing atomic application updates."""

    def __init__(self, app_name):
        self.app_name = app_name
        self.download_url = None
        self.remote_last_modified = None
        self.new_dir = None
        self.old_dir = None
        self.app_dir = None
        self.opt_dir = None

    def set_download_url(self, url):
        """Set the download URL for the application archive."""
        self.download_url = url
        return self

    def set_remote_last_modified(self, timestamp):
        """Set the remote Last-Modified timestamp."""
        self.remote_last_modified = timestamp
        return self

    def set_new_dir(self, path):
        """Set the temporary directory for the new installation."""
        self.new_dir = path
        return self

    def set_old_dir(self, path):
        """Set the backup directory for the old installation."""
        self.old_dir = path
        return self

    def set_app_dir(self, path):
        """Set the final installation directory."""
        self.app_dir = path
        return self

    def set_opt_dir(self, path):
        """Set the root opt directory."""
        self.opt_dir = path
        return self

    def perform(self):
        """Download, extract, atomically install, and write desktop entry."""
        try:
            _download_and_extract(
                self.download_url, self.app_name, self.new_dir, self.opt_dir
            )
            metadata = {
                "last_modified": self.remote_last_modified,
                "download_url": self.download_url,
            }
            version_file = os.path.join(self.new_dir, ".version.json")
            with open(version_file, "w", encoding="utf-8") as fh:
                json.dump(metadata, fh)

            if os.path.exists(self.app_dir):
                if os.path.exists(self.old_dir):
                    shutil.rmtree(self.old_dir)
                os.rename(self.app_dir, self.old_dir)

            os.rename(self.new_dir, self.app_dir)
            chown_to_user(self.app_dir)
            print(f"Update complete: {self.app_name} installed to {self.app_dir}")

            write_desktop_entry(self.app_name, self.app_dir)

        except RuntimeError as exc:
            print(f"Error during update: {exc}", file=sys.stderr)
            if os.path.exists(self.new_dir):
                shutil.rmtree(self.new_dir)
        finally:
            if os.path.exists(self.old_dir):
                try:
                    shutil.rmtree(self.old_dir)
                except OSError:
                    pass


def check_and_update(app_name, force=False):  # pylint: disable=too-many-locals
    """Check for a newer version of *app_name* and install it atomically if found."""
    user_home = get_user_home()
    config_dir = os.path.join(user_home, ".config", "antigravity")
    last_check_file = os.path.join(config_dir, f"last_check_{app_name}")
    opt_dir = os.path.join(user_home, ".local", "opt")
    app_dir = os.path.join(opt_dir, app_name)
    version_file = os.path.join(app_dir, ".version.json")

    should_check = force or _is_update_due(last_check_file)

    # Load installed metadata
    installed_metadata = {}
    if os.path.exists(version_file):
        try:
            with open(version_file, "r", encoding="utf-8") as fh:
                installed_metadata = json.load(fh)
        except (OSError, json.JSONDecodeError):
            pass

    if not should_check:
        if os.path.exists(app_dir):
            return
        print(f"Installation directory {app_dir} is missing. Forcing installation...")

    print(f"Checking for updates for {app_name}...")
    _save_check_timestamp(config_dir, last_check_file)

    try:
        download_url, remote_last_modified = discover_download_url(app_name)
    except RuntimeError as exc:
        print(
            f"Warning: Failed to discover release info: {exc}. "
            "Proceeding with installed version if available.",
            file=sys.stderr,
        )
        return

    installed_last_modified = installed_metadata.get("last_modified")
    if os.path.exists(app_dir) and installed_last_modified == remote_last_modified:
        print(f"{app_name} is up-to-date.")
        write_desktop_entry(app_name, app_dir)
        return

    print(f"New version available (Released: {remote_last_modified})")

    os.makedirs(opt_dir, exist_ok=True)
    chown_to_user(opt_dir)
    if not os.access(opt_dir, os.W_OK):
        print(
            f"Error: No write permission to {opt_dir}. Skipping update.",
            file=sys.stderr,
        )
        return

    new_dir = app_dir + ".new"
    old_dir = app_dir + ".old"

    if os.path.exists(new_dir):
        shutil.rmtree(new_dir)
    os.makedirs(new_dir, exist_ok=True)
    chown_to_user(new_dir)

    updater = Updater(app_name)
    updater.set_download_url(download_url)
    updater.set_remote_last_modified(remote_last_modified)
    updater.set_new_dir(new_dir)
    updater.set_old_dir(old_dir)
    updater.set_app_dir(app_dir)
    updater.set_opt_dir(opt_dir)
    updater.perform()


# ---------------------------------------------------------------------------
# Desktop integration
# ---------------------------------------------------------------------------


def write_desktop_entry(app_name, app_dir):
    """Write a ``.desktop`` launcher for *app_name* to ``~/.local/share/applications/``.

    ``Exec=`` points to the wrapper in ``~/.local/bin/`` so that GUI launches
    still benefit from the auto-update check.
    """
    user_home = get_user_home()
    apps_dir = os.path.join(user_home, ".local", "share", "applications")
    desktop_file = os.path.join(apps_dir, f"{app_name}.desktop")
    wrapper_bin = os.path.join(user_home, ".local", "bin", app_name)

    if not find_file_recursive(app_dir, app_name, is_executable=True):
        print(
            f"Warning: Executable '{app_name}' not found in {app_dir}. "
            "Skipping .desktop file creation.",
            file=sys.stderr,
        )
        return

    icon_path = find_icon_recursive(app_dir, app_name) or "utilities-terminal"
    display_name = "Antigravity IDE" if app_name == "antigravity-ide" else "Antigravity"
    comment = (
        "Google Antigravity IDE"
        if app_name == "antigravity-ide"
        else "Google Antigravity Platform"
    )

    desktop_content = (
        f"[Desktop Entry]\n"
        f"Name={display_name}\n"
        f"Comment={comment}\n"
        f"Exec={wrapper_bin} %U\n"
        f"Icon={icon_path}\n"
        f"Terminal=false\n"
        f"Type=Application\n"
        f"Categories=Development;\n"
    )
    try:
        os.makedirs(apps_dir, exist_ok=True)
        chown_to_user(apps_dir)
        with open(desktop_file, "w", encoding="utf-8") as fh:
            fh.write(desktop_content)
        os.chmod(desktop_file, 0o755)
        chown_to_user(desktop_file)
    except OSError as exc:
        print(
            f"Warning: Failed to create desktop launcher {desktop_file}: {exc}",
            file=sys.stderr,
        )


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main():
    """Detect the target app, check for updates, then exec the installed binary."""
    is_ide = "ide" in os.path.basename(sys.argv[0]).lower()
    app_name = "antigravity-ide" if is_ide else "antigravity"
    force_update = "--update" in sys.argv
    # On ChromeOS (Crostini) there is no system-level way to silence
    # Antigravity's desktop notifications, and they can cover the interaction
    # buttons in agent workflows.  Setting DBUS_SESSION_BUS_ADDRESS to
    # /dev/null before exec makes the app unable to reach D-Bus, suppressing
    # all notifications without affecting core functionality.
    no_notifications = (
        "--no-notifications" in sys.argv
        or os.environ.get("ANTIGRAVITY_NOTIFICATIONS", "").lower() == "no"
    )

    self_install()
    check_and_update(app_name, force=force_update)

    if force_update:
        print("Update operation completed.")
        sys.exit(0)

    if no_notifications:
        os.environ["DBUS_SESSION_BUS_ADDRESS"] = "/dev/null"

    user_home = get_user_home()
    app_dir = os.path.join(user_home, ".local", "opt", app_name)
    resolved_bin = find_file_recursive(app_dir, app_name, is_executable=True)

    if not resolved_bin:
        print(
            f"Error: {app_name} is not installed and could not be loaded.",
            file=sys.stderr,
        )
        print(
            "Please check your internet connection and run again to install.",
            file=sys.stderr,
        )
        sys.exit(1)

    exec_args = [resolved_bin] + [
        a for a in sys.argv[1:] if a not in ("--update", "--no-notifications")
    ]
    try:
        os.execv(resolved_bin, exec_args)
    except OSError as exc:
        print(f"Error: Failed to execute {resolved_bin}: {exc}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
